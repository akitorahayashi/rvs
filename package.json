{
  "name": "bun-cli",
  "version": "0.1.0",
  "description": "Bun and TypeScript CLI template",
  "packageManager": "bun@1.3.14",
  "module": "src/bun_cli/main.ts",
  "type": "module",
  "private": true,
  "bin": {
    "bun-cli": "./src/bun_cli/main.ts"
  },
  "scripts": {
    "bun-cli": "bun src/bun_cli/main.ts",
    "prebuild": "mkdir -p dist",
    "build": "bun build src/bun_cli/main.ts --compile --outfile dist/bun-cli && rm -f .*.bun-build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && bun run typecheck",
    "fix": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "cac": "6.7.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "1.3.14",
    "husky": "9.1.7",
    "typescript": "6.0.3"
  }
}
