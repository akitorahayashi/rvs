{
  "name": "rvs",
  "version": "0.1.0",
  "description": "Remotion vertical shorts renderer",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "private": true,
  "scripts": {
    "rvs": "bun src/rvs/main.ts",
    "serve": "bun run rvs serve",
    "s": "bun run rvs s",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && bun run typecheck",
    "fix": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.454",
    "@remotion/media-parser": "4.0.454",
    "@remotion/renderer": "4.0.454",
    "cac": "6.7.14",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.454",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "husky": "9.1.7",
    "typescript": "6.0.3"
  }
}
